{
  "name": "userdictionaryutil",
  "productName": "UserDictionaryUtil",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run build:electron",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "plist": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/plist": "^3.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.1.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "wait-on": "^8.0.2"
  }
}
